# ── Agent Mode ──────────────────────────────────────────────────────
# "deterministic" = keyword-matching pipeline (no LLM, no AWS)
# "nova"          = Amazon Nova Pro via Bedrock (requires AWS credentials)
AGENT_MODE="nova"

# ── AWS Credentials ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REPLACE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_ME_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_BEDROCK_REGION=us-east-1

# ── Terraform State Backend (created by terraform/bootstrap) ────────
TF_STATE_BUCKET=REPLACE_ME_TF_STATE_BUCKET
TF_STATE_KEY=ec2/terraform.tfstate

# ── GitHub ─────────────────────────────────────────────────────────
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_TOKEN=REPLACE_ME_GITHUB_TOKEN

# ── PagerDuty ──────────────────────────────────────────────────────
PAGERDUTY_ROUTING_KEY=REPLACE_ME_PAGERDUTY_ROUTING_KEY

# ── Scan Tuning ─────────────────────────────────────────────────────
# Optional: Bedrock bearer token (if using a non-AWS provider)
AWS_BEARER_TOKEN_BEDROCK=REPLACE_ME_BEDROCK_TOKEN

# NOTE: Do NOT commit real secrets. Copy this file to `.env` locally and
# fill in real values. The repository should keep only this example file.
# ── Agent Mode ──────────────────────────────────────────────────────
# "deterministic" = keyword-matching pipeline (no LLM, no AWS)
# "nova"          = Amazon Nova Pro via Bedrock (requires AWS credentials)
AGENT_MODE="deterministic"

# ── AWS Credentials ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_BEDROCK_REGION="us-east-1"

# ── Terraform State Backend ─────────────────────────────────────────
TF_STATE_BUCKET="aws-terraform-drift-reconciler-state-605134452604"
TF_STATE_KEY="ec2/terraform.tfstate"
TERRAFORM_DIR="./terraform"

# ── GitHub ──────────────────────────────────────────────────────────
GITHUB_REPO="digambarrajaram/AWS-Terraform-Drift-Reconciler"
GITHUB_BRANCH="drift"
GITHUB_TOKEN=""

# ── PagerDuty ───────────────────────────────────────────────────────
PAGERDUTY_ROUTING_KEY="default-service@digambar.pagerduty.com"

# ── Scan Tuning ─────────────────────────────────────────────────────
# Note: artificial demo scan delays have been removed; scans run immediately.

# ── API access control ──────────────────────────────────────────────
# If set, destructive endpoints require header `X-Api-Access-Token: <value>`
API_ACCESS_TOKEN=""
