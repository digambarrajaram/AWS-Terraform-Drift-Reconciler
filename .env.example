# ── Agent Mode ──────────────────────────────────────────────────────
# "deterministic" = keyword-matching pipeline (no LLM, no AWS)
# "nova"          = Amazon Nova Pro via Bedrock (requires AWS credentials)
AGENT_MODE="deterministic"

# ── AWS Credentials ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
AWS_BEDROCK_REGION="us-east-1"

# ── Terraform State Backend ─────────────────────────────────────────
TF_STATE_BUCKET="aws-terraform-drift-reconciler-state-605134452604"
TF_STATE_KEY="ec2/terraform.tfstate"
TERRAFORM_DIR="./terraform"

# ── GitHub ──────────────────────────────────────────────────────────
GITHUB_REPO="digambarrajaram/AWS-Terraform-Drift-Reconciler"
GITHUB_BRANCH="drift"
GITHUB_TOKEN=""

# ── PagerDuty ───────────────────────────────────────────────────────
# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_ANON_KEY="eyJ..."

# ── PagerDuty ───────────────────────────────────────────────────────
PAGERDUTY_ROUTING_KEY="default-service@digambar.pagerduty.com"

# ── Scan Tuning ─────────────────────────────────────────────────────
# Note: artificial demo scan delays have been removed; scans run immediately.

# ── API access control ──────────────────────────────────────────────
# If set, destructive endpoints require header `X-Api-Access-Token: <value>`
API_ACCESS_TOKEN=""
