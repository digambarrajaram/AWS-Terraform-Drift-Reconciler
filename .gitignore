# Dependencies
node_modules/

# Build outputs
build/
dist/
/dist

# Coverage & testing
coverage/

# Environment & secrets (regenerate from .env.example)
# Keep the example in the repo, but never commit a real `.env` or tfstate files.
.env
.env.local
.env.*.local
!.env.example

# OS & IDE
.DS_Store
.aider*

# Logs
*.log

# Python cache
__pycache__/
*.pyc
*.pyo

# Temporary files
*.tmp
*.swp
*.swo

# Terraform state backups (local; remote state is in S3)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Ignore any tfstate produced by subfolders
**/*.tfstate
**/*.tfstate.backup

# Ignore build artifacts emitted into repo
dist/
dist/*
